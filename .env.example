# myAiRouter Environment Configuration
# Copy to .env and adjust for your environment

# Server
PORT=20128
HOST=0.0.0.0

# Data directory (default: ~/.myairouter)
# DATA_DIR=/custom/path

# Frontend dev server (used by Vite proxy)
VITE_API_URL=http://localhost:20128

# Initial password for dashboard access (change me!)
# INITIAL_PASSWORD=changeme

# JWT secret for session cookies
# JWT_SECRET=

# Kilo Code OAuth
# KILOCODE_CLIENT_ID=
# KILOCODE_CLIENT_SECRET=
